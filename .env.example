# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# --- Sanity (headless CMS) ---------------------------------------------
# Create a free Sanity project at https://sanity.io under the team's SAVR
# account, then run `npx sanity init` here to populate these two, or copy
# them from sanity.io/manage.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01

# --- Yoco (payments) -----------------------------------------------------
# Yoco Business Portal > Selling Online > Payment Gateway. Use sk_test_...
# until ready to go live, then swap for sk_live_....
YOCO_SECRET_KEY=
# Yoco Business Portal > Selling Online > Payment Gateway > Webhooks.
# Create a webhook pointing at /api/webhooks/yoco and copy its signing
# secret (starts with whsec_) here.
YOCO_WEBHOOK_SECRET=

# --- Courier Guy / ShipLogic (shipping) -----------------------------------
# Register a sandbox account at https://sandbox.shiplogic.com/register,
# then grab an API key from the sandbox portal.
COURIER_GUY_API_KEY=
COURIER_GUY_API_BASE_URL=https://api.shiplogic.com
# Collection/warehouse address SAVR ships from.
COURIER_GUY_COLLECTION_STREET=
COURIER_GUY_COLLECTION_CITY=Cape Town
COURIER_GUY_COLLECTION_POSTAL_CODE=

# --- Google Sheets (order overview) ---------------------------------------
# Create a Google Cloud service account (console.cloud.google.com) under the
# team's SAVR Google account, enable the Sheets API, download the JSON key,
# then share the target Sheet with the service account's email as Editor.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Paste the private_key field from the downloaded JSON exactly as-is
# (including \n line breaks — they're unescaped automatically at runtime).
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_SHEET_ID=

# --- Resend (transactional email) -----------------------------------------
RESEND_API_KEY=
RESEND_FROM_ADDRESS="SAVR Nutrition <orders@savrnutrition.co.za>"
TEAM_NOTIFICATION_EMAIL=

# --- Site ------------------------------------------------------------------
# Used to build Yoco success/cancel/failure redirect URLs. Set to the
# deployed Vercel/production URL; falls back to the request origin locally.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
